# Compose env defaults for the jk e2e harness. These values are SAFE to
# commit because they only ever touch the locally-built throwaway Jenkins.
# Do NOT reuse the password in any real Jenkins instance.
#
# The harness uses basic auth with the admin password as the secret in
# the jk credentials store; Jenkins accepts a password identically to an
# API token for /api/json calls, and there is no public plugin API to
# inject a known-plaintext API token. See jcasc/jenkins.yaml for context.
JK_E2E_ADMIN_USER=admin
JK_E2E_ADMIN_PASS=admin-password
